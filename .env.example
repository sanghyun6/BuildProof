# GitHub personal access token — optional
# No scopes needed for public repos. Raises API rate limit from 60 to 5,000 req/hr.
GITHUB_TOKEN=

# LLM provider selection — optional, defaults to "auto"
# Allowed values: anthropic | tokenrouter | auto
# auto: prefers TokenRouter → Anthropic → keyword/deterministic fallback
# anthropic: uses Anthropic if ANTHROPIC_API_KEY is set, else fallback
# tokenrouter: uses TokenRouter if TOKENROUTER_API_KEY is set, else fallback
LLM_PROVIDER=

# Anthropic API key — optional
# Enables LLM-based claim extraction and evidence judging when LLM_PROVIDER=anthropic or auto.
ANTHROPIC_API_KEY=

# TokenRouter API key — optional
# Enables LLM-based claim extraction and evidence judging when LLM_PROVIDER=tokenrouter or auto.
# Without this key, the keyword extractor and deterministic judge run as fallback.
TOKENROUTER_API_KEY=
# Model to use via TokenRouter — defaults to MiniMax-M3
TOKENROUTER_MODEL=MiniMax-M3

# Browserbase credentials — optional
# Both values must be set together to enable real Project URL ingestion.
# Without them, Project URL mode uses sample fixture data automatically.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Sentry DSN — optional, enables server-side audit trace and error export.
# Without this, all observability is local only (the in-UI run trace panel always works).
SENTRY_DSN=

# Judge comparison mode — optional, defaults to off
# When set to "on" AND both ANTHROPIC_API_KEY and TOKENROUTER_API_KEY are configured,
# every audit runs both judges in parallel on the same compressed evidence payload and
# reports per-claim agreement / disagreement. The canonical verdict still comes from the
# primary (LLM_PROVIDER-selected) judge — comparison is observability-only.
# If either key is missing, comparison is skipped silently and the audit runs as normal.
JUDGE_COMPARISON=off

# Band Audit Court UI — experimental, off by default
# Experimental Band Audit Court UI. Keep off for main demo unless fully tested.
# Set to "on" to show the Band panel, copy buttons, self-test, and runbook after each audit.
SHOW_BAND_COURT=off

# The Token Company / evidence compression — all optional
# COMPRESSION_PROVIDER controls how judge context is compressed before being sent to the LLM:
#   off            — no compression; raw judge context sent to LLM
#   local          — always use the local claim-aware compressor
#   token-company  — try The Token Company API, fall back to local compressor on failure
#   auto (default) — use The Token Company if TOKEN_COMPANY_API_KEY is set, else local
# The app always works without these set — compression failures never break the audit.
COMPRESSION_PROVIDER=auto
TOKEN_COMPANY_API_KEY=
# TOKEN_COMPANY_API_URL — required for remote compression to activate.
# The adapter ships with a placeholder (.example) URL that is never called.
# Set this to a real endpoint AND set TOKEN_COMPANY_API_KEY to enable remote calls.
# If either is missing or TOKEN_COMPANY_API_URL is left blank, local compression is used.
TOKEN_COMPANY_API_URL=
